<div class="page-header">
  <h2>Mitarbeiter-Ausgaben</h2>
</div>

<!-- Monatsauswahl -->
<form method="GET" action="/mitarbeiter" class="filter-bar" style="margin-bottom:24px">
  <input type="month" name="monat" value="<%= monat %>" onchange="this.form.submit()"
    style="padding:7px 12px;border:1px solid var(--border);border-radius:8px;font-size:0.9rem;background:#fff;cursor:pointer">
</form>

<div class="ma-layout">

  <!-- ── LINKE SPALTE: Mitarbeiter-Verwaltung ── -->
  <div class="ma-sidebar">
    <div class="ma-card">
      <div class="ma-card-title">Mitarbeiter</div>

      <div id="ma-list">
        <% if (employees.length === 0) { %>
          <p class="ma-empty">Noch keine Mitarbeiter angelegt.</p>
        <% } else { %>
          <% employees.forEach(e => { %>
            <div class="ma-row" id="ma-<%= e.id %>">
              <span class="ma-label"><%= e.label %></span>
              <span class="ma-badge type-<%= e.type %>">
                <%= {vz:'VZ', tz:'TZ', mj:'MJ'}[e.type] %>
              </span>
              <button class="ma-del" onclick="deleteEmployee('<%= e.id %>', '<%= e.label %>')" title="Löschen">✕</button>
            </div>
          <% }) %>
        <% } %>
      </div>

      <!-- Hinzufügen -->
      <div class="ma-add-wrap">
        <input id="new-label" type="text" placeholder="Kürzel (z.B. MA-001)" maxlength="25"
          onkeydown="if(event.key==='Enter')addEmployee()">
        <select id="new-type">
          <option value="vz">Vollzeit</option>
          <option value="tz">Teilzeit</option>
          <option value="mj">Minijob (bis 603 €)</option>
        </select>
        <button class="btn-primary ma-add-btn" onclick="addEmployee()">+ Hinzufügen</button>
      </div>

      <div class="dsgvo-hint">
        Keine Klarnamen notwendig — anonyme Kürzel sind DSGVO-konform.
      </div>
    </div>
  </div>

  <!-- ── RECHTE SPALTE: Kosten + Zusammenfassung ── -->
  <div class="ma-main">

    <!-- Kostentabelle -->
    <div class="ma-card" style="margin-bottom:16px">
      <div class="ma-card-title">Ausgaben — <%= monatLabel %></div>
      <table class="ma-table">
        <thead>
          <tr>
            <th>Kürzel</th>
            <th>Beschäftigung</th>
            <th style="text-align:right">Betrag diesen Monat</th>
          </tr>
        </thead>
        <tbody>
          <% if (employees.length === 0) { %>
            <tr>
              <td colspan="3" style="color:var(--mid);font-style:italic;padding:18px 8px">
                Füge links Mitarbeiter hinzu.
              </td>
            </tr>
          <% } else { %>
            <% employees.forEach(e => { %>
              <tr>
                <td class="ma-tname"><%= e.label %></td>
                <td>
                  <span class="ma-badge type-<%= e.type %>">
                    <%= {vz:'Vollzeit', tz:'Teilzeit', mj:'Minijob'}[e.type] %>
                  </span>
                </td>
                <td style="text-align:right">
                  <input class="ma-cost-inp" type="number" min="0" step="0.01" placeholder="0,00"
                    value="<%= kosten[e.id] !== undefined ? kosten[e.id] : '' %>"
                    oninput="saveCost('<%= e.id %>', this.value)">
                  &nbsp;<span style="color:var(--mid)">€</span>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Zusammenfassung -->
    <div class="ub-section">
      <div class="ub-section-title">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
          <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>
        </svg>
        Zusammenfassung — <%= monatLabel %>
      </div>

      <div class="ub-cards" style="margin-bottom:14px">
        <div class="ub-card">
          <div class="ub-card-label">Rechnungen (brutto 7%)</div>
          <div class="ub-card-value"><%= liefBrutto.toFixed(2).replace('.',',') %> €</div>
          <div class="ub-card-sub">automatisch aus Rechnungen</div>
        </div>
        <div class="ub-card">
          <div class="ub-card-label">Tageskasse</div>
          <div class="ub-card-value"><%= ladenBrutto.toFixed(2).replace('.',',') %> €</div>
          <div class="ub-card-sub">automatisch aus Tageskasse</div>
        </div>
        <div class="ub-card ub-card-primary">
          <div class="ub-card-label">Gesamt-Einnahmen</div>
          <div class="ub-card-value"><%= gesamtEin.toFixed(2).replace('.',',') %> €</div>
        </div>
      </div>

      <div class="ub-cards" style="margin-bottom:14px">
        <div class="ub-card ub-card-warn">
          <div class="ub-card-label">Vollzeit-Kosten</div>
          <div class="ub-card-value" id="sum-vz"><%= summen.vz.toFixed(2).replace('.',',') %> €</div>
        </div>
        <div class="ub-card ub-card-warn">
          <div class="ub-card-label">Teilzeit-Kosten</div>
          <div class="ub-card-value" id="sum-tz"><%= summen.tz.toFixed(2).replace('.',',') %> €</div>
        </div>
        <div class="ub-card ub-card-warn">
          <div class="ub-card-label">Minijob-Kosten</div>
          <div class="ub-card-value" id="sum-mj"><%= summen.mj.toFixed(2).replace('.',',') %> €</div>
        </div>
        <div class="ub-card" style="border-color:#e53935">
          <div class="ub-card-label">Gesamt Ausgaben</div>
          <div class="ub-card-value" id="sum-total" style="color:#e53935"><%= totalKosten.toFixed(2).replace('.',',') %> €</div>
        </div>
      </div>

      <div class="ma-gewinn-box" id="gewinn-box">
        <span class="ma-gewinn-label">GEWINN — <%= monatLabel %></span>
        <span class="ma-gewinn-val <%= gewinn >= 0 ? 'pos' : 'neg' %>" id="gewinn-val">
          <%= gewinn.toFixed(2).replace('.',',') %> €
        </span>
      </div>
    </div>

  </div>
</div>

<style>
.ma-layout {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 20px;
  align-items: start;
}
@media (max-width: 800px) {
  .ma-layout { grid-template-columns: 1fr; }
}

.ma-card {
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 18px 20px;
}
.ma-card-title {
  font-size: 0.8rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--mid);
  margin-bottom: 14px;
}

.ma-row {
  display: flex;
  align-items: center;
  gap: 7px;
  padding: 6px 8px;
  border-radius: 7px;
  margin-bottom: 5px;
  background: var(--bg);
  border: 1px solid var(--border);
}
.ma-label { flex: 1; font-size: 0.88rem; font-weight: 600; color: var(--dark); }
.ma-del {
  background: none;
  border: none;
  color: #ccc;
  cursor: pointer;
  font-size: 14px;
  padding: 0 2px;
  line-height: 1;
}
.ma-del:hover { color: #e53935; }
.ma-empty { font-size: 0.82rem; color: var(--mid); font-style: italic; margin-bottom: 12px; }

.ma-badge {
  font-size: 0.7rem;
  font-weight: 700;
  padding: 2px 8px;
  border-radius: 10px;
  white-space: nowrap;
}
.type-vz { background: #e3f0ff; color: #1565c0; }
.type-tz { background: #f3e8ff; color: #6a1b9a; }
.type-mj { background: #fff3e0; color: #e65100; }

.ma-add-wrap {
  margin-top: 14px;
  display: flex;
  flex-direction: column;
  gap: 7px;
}
.ma-add-wrap input,
.ma-add-wrap select {
  width: 100%;
  padding: 7px 10px;
  border: 1px solid var(--border);
  border-radius: 7px;
  font-size: 0.88rem;
  background: var(--bg);
  color: var(--dark);
}
.ma-add-btn { width: 100%; margin-top: 2px; }

.dsgvo-hint {
  margin-top: 14px;
  padding: 8px 12px;
  background: #f0f7ff;
  border: 1px solid #b3d4f5;
  border-radius: 7px;
  font-size: 0.75rem;
  color: #1565c0;
  line-height: 1.5;
}

.ma-table {
  width: 100%;
  border-collapse: collapse;
}
.ma-table th {
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--mid);
  font-weight: 600;
  padding: 5px 8px;
  border-bottom: 1px solid var(--border);
  text-align: left;
}
.ma-table td {
  padding: 9px 8px;
  border-bottom: 1px solid var(--border);
  vertical-align: middle;
}
.ma-table tr:last-child td { border-bottom: none; }
.ma-tname { font-weight: 600; font-size: 0.9rem; color: var(--dark); }

.ma-cost-inp {
  width: 130px;
  padding: 6px 10px;
  border: 1px solid var(--border);
  border-radius: 6px;
  font-size: 0.9rem;
  font-weight: 600;
  text-align: right;
  background: #fff8f8;
  color: #c62828;
}
.ma-cost-inp:focus { outline: none; border-color: #e53935; }

.ma-gewinn-box {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--dark);
  border-radius: 10px;
  padding: 14px 20px;
}
.ma-gewinn-label { font-weight: 700; font-size: 0.95rem; color: #fff; }
.ma-gewinn-val { font-size: 1.7rem; font-weight: 900; }
.ma-gewinn-val.pos { color: #69f0ae; }
.ma-gewinn-val.neg { color: #ff5252; }

/* Reuse ub-* classes from Überblick */
.ub-section {
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 20px 22px;
}
.ub-section-title {
  display: flex;
  align-items: center;
  gap: 8px;
  font-weight: 700;
  font-size: 0.88rem;
  letter-spacing: 0.03em;
  color: var(--dark);
  margin-bottom: 16px;
}
.ub-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: 10px;
}
.ub-card { background: var(--bg); border: 1px solid var(--border); border-radius: 10px; padding: 12px 16px; }
.ub-card-primary { background: #fff; border-color: var(--gold); }
.ub-card-warn { background: #fffaf4; border-color: #f0a04b; }
.ub-card-label { font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--mid); margin-bottom: 5px; }
.ub-card-value { font-size: 1.2rem; font-weight: 700; color: var(--dark); }
.ub-card-sub { font-size: 0.75rem; color: var(--mid); margin-top: 3px; }
</style>

<script>
const CURRENT_MONAT = '<%= monat %>';
let saveTimer = null;

// Mitarbeiter hinzufügen
async function addEmployee() {
  const label = document.getElementById('new-label').value.trim();
  if (!label) { alert('Bitte ein Kürzel eingeben.'); return; }
  const type = document.getElementById('new-type').value;
  const id = 'ma' + Date.now();
  const r = await fetch('/mitarbeiter/ma', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id, label, type })
  });
  if (r.ok) location.reload();
  else alert('Fehler beim Hinzufügen.');
}

// Mitarbeiter löschen
async function deleteEmployee(id, label) {
  if (!confirm(`Mitarbeiter "${label}" und alle Kosten-Einträge löschen?`)) return;
  const r = await fetch('/mitarbeiter/ma/' + id, { method: 'DELETE' });
  if (r.ok) location.reload();
  else alert('Fehler beim Löschen.');
}

// Kosten speichern (auto-save mit Debounce)
function saveCost(maId, value) {
  clearTimeout(saveTimer);
  saveTimer = setTimeout(async () => {
    await fetch(`/mitarbeiter/kosten/${CURRENT_MONAT}/${maId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ betrag: value === '' ? null : parseFloat(value) || 0 })
    });
    recalc();
  }, 500);
}

// Summen live neu berechnen
function recalc() {
  const employees = <%- JSON.stringify(employees) %>;
  const inputs = document.querySelectorAll('.ma-cost-inp');
  const vals = {};
  inputs.forEach(inp => {
    const maId = inp.closest('tr')?.querySelector('.ma-cost-inp')?.dataset?.id || inp.getAttribute('oninput').match(/'([^']+)'/)?.[1];
    // Simpler: just read from oninput attribute
  });

  // Re-read all cost inputs by employee order
  const sums = { vz: 0, tz: 0, mj: 0 };
  inputs.forEach((inp, i) => {
    const e = employees[i];
    if (!e) return;
    const v = parseFloat(inp.value) || 0;
    sums[e.type] = (sums[e.type] || 0) + v;
  });

  const total = sums.vz + sums.tz + sums.mj;
  const einnahmen = <%= gesamtEin %>;
  const gewinn = einnahmen - total;

  const fmt = n => n.toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' €';

  const sv = document.getElementById('sum-vz');     if(sv) sv.textContent = fmt(sums.vz);
  const st = document.getElementById('sum-tz');     if(st) st.textContent = fmt(sums.tz);
  const sm = document.getElementById('sum-mj');     if(sm) sm.textContent = fmt(sums.mj);
  const so = document.getElementById('sum-total');  if(so) so.textContent = fmt(total);
  const gv = document.getElementById('gewinn-val');
  if (gv) {
    gv.textContent = fmt(gewinn);
    gv.className = 'ma-gewinn-val ' + (gewinn >= 0 ? 'pos' : 'neg');
  }
}
</script>
