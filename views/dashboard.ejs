<div class="page-header">
  <h2>Dashboard</h2>
  <a href="/rechnungen/neu" class="btn-primary">+ Neue Rechnung</a>
</div>

<!-- ── FILTER BAR ─────────────────────────────────────────────────── -->
<div class="filter-bar">

  <!-- Jahre -->
  <div class="filter-group">
    <span class="filter-label">Jahr</span>
    <a href="/dashboard" class="filter-pill <%= filter.year === 'all' ? 'active' : '' %>">Alle</a>
    <% availableYears.forEach(y => { %>
      <a href="/dashboard?year=<%= y %>"
         class="filter-pill <%= filter.year == y && !filter.month && !filter.quarter ? 'active' : '' %>">
        <%= y %>
      </a>
    <% }) %>
  </div>

  <% if (filter.year !== 'all') { %>

  <!-- Quartale -->
  <div class="filter-group">
    <span class="filter-label">Quartal</span>
    <% [1,2,3,4].forEach(q => { %>
      <a href="/dashboard?year=<%= filter.year %>&quarter=<%= q %>"
         class="filter-pill <%= filter.quarter === q ? 'active' : '' %>">
        Q<%= q %>
      </a>
    <% }) %>
  </div>

  <!-- Monate -->
  <div class="filter-group">
    <span class="filter-label">Monat</span>
    <div class="filter-months">
      <% monthNames.forEach((m, i) => { %>
        <a href="/dashboard?year=<%= filter.year %>&month=<%= i+1 %>"
           class="filter-pill <%= filter.month === i+1 ? 'active' : '' %>">
          <%= m %>
        </a>
      <% }) %>
    </div>
  </div>

  <% } %>
</div>

<!-- ── STATS ──────────────────────────────────────────────────────── -->
<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-value"><%= stats.invoices %></div>
    <div class="stat-label">Rechnungen · <%= periodLabel %></div>
  </div>
  <div class="stat-card">
    <div class="stat-value"><%= stats.customers %></div>
    <div class="stat-label">Kunden gesamt</div>
  </div>
  <div class="stat-card">
    <div class="stat-value"><%= stats.articles %></div>
    <div class="stat-label">Artikel aktiv</div>
  </div>
  <div class="stat-card accent">
    <div class="stat-value"><%= stats.revenue.toFixed(2).replace('.', ',') %> €</div>
    <div class="stat-label">Umsatz netto · <%= periodLabel %></div>
  </div>
</div>

<!-- ── GESAMTÜBERSICHT ────────────────────────────────────────────── -->
<div class="db-uebersicht">

  <div class="db-ub-row">
    <div class="db-ub-card">
      <div class="db-ub-label">Rechnungen (brutto)</div>
      <div class="db-ub-val"><%= uebersicht.liefBrutto.toFixed(2).replace('.',',') %> €</div>
    </div>
    <div class="db-ub-card">
      <div class="db-ub-label">Tageskasse</div>
      <div class="db-ub-val"><%= uebersicht.ladenBrutto.toFixed(2).replace('.',',') %> €</div>
    </div>
    <div class="db-ub-card db-ub-ein">
      <div class="db-ub-label">Gesamt-Einnahmen</div>
      <div class="db-ub-val"><%= uebersicht.gesamtEin.toFixed(2).replace('.',',') %> €</div>
    </div>
    <div class="db-ub-card db-ub-aus">
      <div class="db-ub-label">Mitarbeiter-Kosten</div>
      <div class="db-ub-val">− <%= uebersicht.maKosten.toFixed(2).replace('.',',') %> €</div>
    </div>
    <div class="db-ub-card db-ub-gewinn">
      <div class="db-ub-label">Gewinn · <%= periodLabel %></div>
      <div class="db-ub-val db-ub-gewinn-val <%= uebersicht.gewinn >= 0 ? 'pos' : 'neg' %>">
        <%= uebersicht.gewinn.toFixed(2).replace('.',',') %> €
      </div>
    </div>
  </div>

</div>

<!-- ── RECHNUNGSLISTE ─────────────────────────────────────────────── -->
<div class="card">
  <div class="card-header">
    <h3><%= filter.year === 'all' ? 'Letzte Rechnungen' : 'Rechnungen · ' + periodLabel %></h3>
    <a href="/rechnungen" class="link">Alle anzeigen →</a>
  </div>
  <% if (latestInvoices.length === 0) { %>
    <p class="empty-state">Keine Rechnungen im gewählten Zeitraum.</p>
  <% } else { %>
  <table class="data-table">
    <thead>
      <tr>
        <th>Nr.</th>
        <th>Datum</th>
        <th>Kunde</th>
        <th>Netto</th>
        <th>Brutto</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% latestInvoices.forEach(inv => {
        const netto = inv.total_netto || 0;
        const brutto = netto * 1.07;
      %>
      <tr>
        <td><strong>#<%= inv.invoice_number %></strong></td>
        <td><%= new Date(inv.date).toLocaleDateString('de-DE') %></td>
        <td><%= inv.customer_name || '—' %></td>
        <td><%= netto.toFixed(2).replace('.',',') %> €</td>
        <td><strong><%= brutto.toFixed(2).replace('.',',') %> €</strong></td>
        <td><a href="/rechnungen/<%= inv.id %>" class="link">Öffnen →</a></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<style>
.db-uebersicht { margin-bottom: 22px; }
.db-ub-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: 12px;
}
.db-ub-card {
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 14px 18px;
}
.db-ub-ein    { border-color: var(--gold); }
.db-ub-aus    { background: #fffaf4; border-color: #f0a04b; }
.db-ub-gewinn { background: var(--dark); border-color: var(--dark); }
.db-ub-label {
  font-size: 0.7rem; font-weight: 600; text-transform: uppercase;
  letter-spacing: 0.05em; color: var(--mid); margin-bottom: 6px;
}
.db-ub-gewinn .db-ub-label { color: rgba(255,255,255,0.6); }
.db-ub-val { font-size: 1.15rem; font-weight: 700; color: var(--dark); }
.db-ub-gewinn-val { font-size: 1.3rem; }
.db-ub-gewinn-val.pos { color: #69f0ae; }
.db-ub-gewinn-val.neg { color: #ff5252; }
</style>
