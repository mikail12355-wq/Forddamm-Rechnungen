<div class="page-header">
  <h2>Tageskasse</h2>
  <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
    <% if (year !== 'all' && month !== 'all') { %>
      <a href="/tageskasse/kassenbericht-lotto?year=<%= year %>&month=<%= month %>"
         class="btn-secondary" style="background:#f0a04b;color:#fff;border:none">
        Lotto herunterladen
      </a>
      <a href="/tageskasse/kassenbericht-laden?year=<%= year %>&month=<%= month %>"
         class="btn-secondary" style="background:#6fcf97;color:#fff;border:none">
        Laden herunterladen
      </a>
    <% } else { %>
      <span style="font-size:0.82rem;color:var(--mid)">Monat &amp; Jahr wählen für Kassenbericht</span>
    <% } %>
    <a href="/tageskasse/neu" class="btn-primary">+ Neuer Eintrag</a>
  </div>
</div>

<!-- Filter -->
<form method="GET" action="/tageskasse" class="filter-bar" style="margin-bottom:20px">
  <select name="year" onchange="this.form.submit()">
    <option value="all" <%= year === 'all' ? 'selected' : '' %>>Alle Jahre</option>
    <% years.forEach(y => { %>
      <option value="<%= y %>" <%= year === y ? 'selected' : '' %>><%= y %></option>
    <% }) %>
  </select>
  <select name="month" onchange="this.form.submit()">
    <option value="all" <%= month === 'all' ? 'selected' : '' %>>Alle Monate</option>
    <% MONTHS.forEach((m, i) => { %>
      <option value="<%= i+1 %>" <%= String(month) === String(i+1) ? 'selected' : '' %>><%= m %></option>
    <% }) %>
  </select>
</form>

<!-- Summary cards -->
<% if (entries.length > 0) { %>
<div class="stats-grid" style="margin-bottom:24px">
  <div class="stat-card">
    <div class="stat-label">Umsatz 7% (brutto)</div>
    <div class="stat-value"><%= sumR7.toFixed(2).replace('.',',') %> €</div>
    <div class="stat-sub">netto: <%= (sumR7/1.07).toFixed(2).replace('.',',') %> €</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Umsatz 19% (brutto)</div>
    <div class="stat-value"><%= sumR19.toFixed(2).replace('.',',') %> €</div>
    <div class="stat-sub">netto: <%= (sumR19/1.19).toFixed(2).replace('.',',') %> €</div>
  </div>
  <div class="stat-card stat-card-warn">
    <div class="stat-label">Lottokasse (abgezogen)</div>
    <div class="stat-value" style="color:#e67e22">− <%= sumLotto.toFixed(2).replace('.',',') %> €</div>
  </div>
  <div class="stat-card stat-card-green">
    <div class="stat-label">Laden-Umsatz gesamt</div>
    <div class="stat-value"><%= sumBrutto.toFixed(2).replace('.',',') %> €</div>
    <div class="stat-sub">netto: <%= sumNetto.toFixed(2).replace('.',',') %> €</div>
  </div>
</div>
<% } %>

<!-- Table -->
<div class="card" style="padding:0;overflow-x:auto">
  <% if (entries.length === 0) { %>
    <p class="empty-state" style="padding:32px">Noch keine Einträge.
      <a href="/tageskasse/neu">Ersten Eintrag anlegen</a>
    </p>
  <% } else { %>
  <table class="data-table">
    <thead>
      <tr>
        <th>Datum</th>
        <th style="text-align:right">7% brutto</th>
        <th style="text-align:right">7% netto</th>
        <th style="text-align:right">19% brutto</th>
        <th style="text-align:right">19% netto</th>
        <th style="text-align:right">Lotto</th>
        <th style="text-align:right">Gesamt brutto</th>
        <th>Notiz</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% entries.forEach(e => {
           const r7    = Number(e.revenue_7);
           const r19   = Number(e.revenue_19);
           const lotto = Number(e.lotto_revenue);
           const brutto = r7 + r19;
           const netto  = r7 / 1.07 + r19 / 1.19;
      %>
      <tr>
        <td><strong><%= new Date(e.date + 'T12:00:00').toLocaleDateString('de-DE', { weekday:'short', day:'2-digit', month:'2-digit', year:'numeric' }) %></strong></td>
        <td style="text-align:right"><%= r7  > 0 ? r7.toFixed(2).replace('.',',')  + ' €' : '—' %></td>
        <td style="text-align:right;color:var(--mid);font-size:0.85rem"><%= r7  > 0 ? (r7/1.07).toFixed(2).replace('.',',')  + ' €' : '' %></td>
        <td style="text-align:right"><%= r19 > 0 ? r19.toFixed(2).replace('.',',') + ' €' : '—' %></td>
        <td style="text-align:right;color:var(--mid);font-size:0.85rem"><%= r19 > 0 ? (r19/1.19).toFixed(2).replace('.',',') + ' €' : '' %></td>
        <td style="text-align:right;color:<%= lotto > 0 ? '#e67e22' : lotto < 0 ? '#27ae60' : 'var(--mid)' %>"
            title="<%= lotto < 0 ? 'Gewinnausschüttung – wird vom Monatsbetrag abgezogen' : '' %>">
          <% if (lotto > 0) { %>− <%= lotto.toFixed(2).replace('.',',') %> €
          <% } else if (lotto < 0) { %>+ <%= Math.abs(lotto).toFixed(2).replace('.',',') %> € <span style="font-size:0.75rem">(Ausz.)</span>
          <% } else { %>—<% } %>
        </td>
        <td style="text-align:right;font-weight:700"><%= brutto.toFixed(2).replace('.',',') %> €</td>
        <td style="color:var(--mid);font-size:0.82rem"><%= e.notes || '' %></td>
        <td>
          <div class="action-links">
            <a href="/tageskasse/<%= e.id %>/bearbeiten">Bearbeiten</a>
            <form action="/tageskasse/<%= e.id %>/loeschen" method="POST" style="display:inline"
                  onsubmit="return confirm('Eintrag wirklich löschen?')">
              <button type="submit" class="link-danger">Löschen</button>
            </form>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
    <tfoot>
      <tr>
        <td style="font-weight:700">Summe</td>
        <td style="text-align:right;font-weight:700"><%= sumR7.toFixed(2).replace('.',',') %> €</td>
        <td style="text-align:right;color:var(--mid);font-size:0.85rem"><%= (sumR7/1.07).toFixed(2).replace('.',',') %> €</td>
        <td style="text-align:right;font-weight:700"><%= sumR19.toFixed(2).replace('.',',') %> €</td>
        <td style="text-align:right;color:var(--mid);font-size:0.85rem"><%= (sumR19/1.19).toFixed(2).replace('.',',') %> €</td>
        <td style="text-align:right;font-weight:700;color:#e67e22"><%= sumLotto > 0 ? '− ' + sumLotto.toFixed(2).replace('.',',') + ' €' : '—' %></td>
        <td style="text-align:right;font-weight:700"><%= sumBrutto.toFixed(2).replace('.',',') %> €</td>
        <td colspan="2"></td>
      </tr>
    </tfoot>
  </table>
  <% } %>
</div>

<style>
.stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 14px; }
.stat-card {
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 16px 20px;
}
.stat-card-warn  { border-color: #f0a04b; background: #fffaf4; }
.stat-card-green { border-color: #6fcf97; background: #f4fcf7; }
.stat-label { font-size: 0.72rem; color: var(--mid); font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 6px; }
.stat-value { font-size: 1.3rem; font-weight: 700; color: var(--dark); }
.stat-sub   { font-size: 0.8rem; color: var(--mid); margin-top: 4px; }
</style>
