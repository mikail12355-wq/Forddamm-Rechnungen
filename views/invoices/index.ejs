<div class="page-header">
  <h2>Rechnungen</h2>
  <a href="/rechnungen/neu" class="btn-primary">+ Neue Rechnung</a>
</div>

<div class="filter-bar">
  <%
    const qs = (overrides) => {
      const p = { search, sort, status, year, period, ...overrides };
      return Object.entries(p).filter(([,v]) => v && v !== 'all' && v !== '').map(([k,v]) => k + '=' + encodeURIComponent(v)).join('&');
    };
  %>

  <!-- Suche + Sortierung -->
  <form class="filter-group" method="GET" action="/rechnungen" style="gap:8px">
    <input type="hidden" name="status" value="<%= status %>" />
    <input type="hidden" name="year"   value="<%= year %>" />
    <input type="hidden" name="period" value="<%= period %>" />
    <input type="text" name="search" placeholder="Nr., Kunde, Bestellnr. …" value="<%= search %>" style="flex:1;min-width:180px" />
    <select name="sort" onchange="this.form.submit()" style="width:auto">
      <option value="desc" <%= sort==='desc'?'selected':'' %>>Neueste zuerst</option>
      <option value="asc"  <%= sort==='asc'?'selected':'' %>>Älteste zuerst</option>
    </select>
    <button type="submit" class="btn-secondary">Suchen</button>
    <% if (search) { %><a href="/rechnungen?<%= qs({search:''}) %>" class="btn-ghost">✕</a><% } %>
  </form>

  <!-- Jahr -->
  <div class="filter-group">
    <span class="filter-label">Jahr</span>
    <div class="filter-months">
      <a href="/rechnungen?<%= qs({year:'all',period:'all'}) %>" class="filter-pill <%= year==='all' ? 'active' : '' %>">Alle</a>
      <% years.forEach(y => { %>
        <a href="/rechnungen?<%= qs({year:y}) %>" class="filter-pill <%= year===y ? 'active' : '' %>"><%= y %></a>
      <% }) %>
    </div>
  </div>

  <!-- Quartal -->
  <div class="filter-group">
    <span class="filter-label">Quartal</span>
    <div class="filter-months">
      <a href="/rechnungen?<%= qs({period:'all'}) %>" class="filter-pill <%= period==='all' ? 'active' : '' %>">Alle</a>
      <% [['Q1','Jan–Mär'],['Q2','Apr–Jun'],['Q3','Jul–Sep'],['Q4','Okt–Dez']].forEach(([q,label]) => { %>
        <a href="/rechnungen?<%= qs({period:q}) %>" class="filter-pill <%= period===q ? 'active' : '' %>"><%= q %> <span style="font-weight:400;opacity:0.75"><%= label %></span></a>
      <% }) %>
    </div>
  </div>

  <!-- Monat -->
  <div class="filter-group">
    <span class="filter-label">Monat</span>
    <div class="filter-months">
      <% ['01','02','03','04','05','06','07','08','09','10','11','12'].forEach((m,i) => {
         const names = ['Jan','Feb','Mär','Apr','Mai','Jun','Jul','Aug','Sep','Okt','Nov','Dez'];
      %>
        <a href="/rechnungen?<%= qs({period:m}) %>" class="filter-pill <%= period===m ? 'active' : '' %>"><%= names[i] %></a>
      <% }) %>
    </div>
  </div>

  <!-- Status + Export -->
  <div class="filter-group" style="justify-content:space-between;flex-wrap:wrap;gap:12px">
    <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap">
      <span class="filter-label">Status</span>
      <div class="filter-months">
        <a href="/rechnungen?<%= qs({status:'all'}) %>"  class="filter-pill <%= status==='all'  ? 'active' : '' %>">Alle</a>
        <a href="/rechnungen?<%= qs({status:'open'}) %>" class="filter-pill filter-pill--open <%= status==='open' ? 'active' : '' %>">Offen</a>
        <a href="/rechnungen?<%= qs({status:'paid'}) %>" class="filter-pill filter-pill--paid <%= status==='paid' ? 'active' : '' %>">Bezahlt</a>
      </div>
    </div>
    <a href="/rechnungen/export?<%= qs({}) %>" class="btn-export">⬇ PDFs herunterladen (<%= invoices.length %>)</a>
  </div>
</div>

<div class="card">
  <% if (invoices.length === 0) { %>
    <p class="empty-state">Keine Rechnungen gefunden.</p>
  <% } else { %>
  <%
    const totalNetto  = invoices.reduce((s, inv) => s + (inv.total_netto || 0), 0);
    const totalBrutto = totalNetto * 1.07;
  %>
  <div class="invoices-summary">
    <span><strong><%= invoices.length %></strong> Rechnung<%= invoices.length !== 1 ? 'en' : '' %></span>
    <span>Netto gesamt: <strong><%= totalNetto.toFixed(2).replace('.',',') %> €</strong></span>
    <span>Brutto gesamt: <strong><%= totalBrutto.toFixed(2).replace('.',',') %> €</strong></span>
  </div>
  <table class="data-table">
    <thead>
      <tr>
        <th>Nr.</th>
        <th>Datum</th>
        <th>Lieferdatum</th>
        <th>Kunde</th>
        <th>Bestellnr.</th>
        <th>Netto</th>
        <th>Brutto</th>
        <th>Status</th>
        <th>Aktionen</th>
      </tr>
    </thead>
    <tbody>
      <% invoices.forEach(inv => {
        const netto = inv.total_netto || 0;
        const brutto = netto * 1.07;
        const isPaid = inv.paid == 1;
      %>
      <tr>
        <td><strong>#<%= inv.invoice_number %></strong></td>
        <td><%= new Date(inv.date).toLocaleDateString('de-DE') %></td>
        <td>
          <% if (inv.delivery_from) { %>
            <%= new Date(inv.delivery_from).toLocaleDateString('de-DE') %>
            <% if (inv.delivery_to) { %>–<%= new Date(inv.delivery_to).toLocaleDateString('de-DE') %><% } %>
          <% } else { %>—<% } %>
        </td>
        <td><%= inv.customer_name || '—' %></td>
        <td class="text-muted"><%= inv.order_number || '—' %></td>
        <td><%= netto.toFixed(2).replace('.',',') %> €</td>
        <td><strong><%= brutto.toFixed(2).replace('.',',') %> €</strong></td>
        <td>
          <form action="/rechnungen/<%= inv.id %>/zahlung" method="POST" style="display:inline">
            <input type="hidden" name="back" value="/rechnungen?<%= qs({}) %>" />
            <button type="submit" class="paid-toggle <%= isPaid ? 'paid-toggle--paid' : 'paid-toggle--open' %>">
              <%= isPaid ? '✓ Bezahlt' : '○ Offen' %>
            </button>
          </form>
          <% if (isPaid && inv.paid_at) { %>
            <div class="paid-date"><%= new Date(inv.paid_at).toLocaleDateString('de-DE') %></div>
          <% } %>
        </td>
        <td>
          <div class="action-links">
            <a href="/rechnungen/<%= inv.id %>">Ansehen</a>
            <a href="/rechnungen/<%= inv.id %>/pdf">PDF</a>
            <a href="/rechnungen/<%= inv.id %>/bearbeiten">Bearbeiten</a>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
