<div class="page-header">
  <h2>Gesamtüberblick</h2>
</div>

<!-- Filter -->
<form method="GET" action="/uebersicht" class="filter-bar" style="margin-bottom:28px">
  <select name="year" onchange="this.form.submit()">
    <option value="all" <%= year === 'all' ? 'selected' : '' %>>Alle Jahre</option>
    <% years.forEach(y => { %>
      <option value="<%= y %>" <%= year === y ? 'selected' : '' %>><%= y %></option>
    <% }) %>
  </select>
  <select name="period" onchange="this.form.submit()">
    <option value="all" <%= period === 'all' ? 'selected' : '' %>>Gesamtes Jahr</option>
    <option value="Q1" <%= period === 'Q1' ? 'selected' : '' %>>Q1 (Jan–Mrz)</option>
    <option value="Q2" <%= period === 'Q2' ? 'selected' : '' %>>Q2 (Apr–Jun)</option>
    <option value="Q3" <%= period === 'Q3' ? 'selected' : '' %>>Q3 (Jul–Sep)</option>
    <option value="Q4" <%= period === 'Q4' ? 'selected' : '' %>>Q4 (Okt–Dez)</option>
    <option value="1"  <%= period === '1'  ? 'selected' : '' %>>Januar</option>
    <option value="2"  <%= period === '2'  ? 'selected' : '' %>>Februar</option>
    <option value="3"  <%= period === '3'  ? 'selected' : '' %>>März</option>
    <option value="4"  <%= period === '4'  ? 'selected' : '' %>>April</option>
    <option value="5"  <%= period === '5'  ? 'selected' : '' %>>Mai</option>
    <option value="6"  <%= period === '6'  ? 'selected' : '' %>>Juni</option>
    <option value="7"  <%= period === '7'  ? 'selected' : '' %>>Juli</option>
    <option value="8"  <%= period === '8'  ? 'selected' : '' %>>August</option>
    <option value="9"  <%= period === '9'  ? 'selected' : '' %>>September</option>
    <option value="10" <%= period === '10' ? 'selected' : '' %>>Oktober</option>
    <option value="11" <%= period === '11' ? 'selected' : '' %>>November</option>
    <option value="12" <%= period === '12' ? 'selected' : '' %>>Dezember</option>
  </select>
</form>

<!-- ══ LIEFERUNGEN ══════════════════════════════════════════════════════════ -->
<div class="ub-section">
  <div class="ub-section-title">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
    Lieferungen (Ausgangsrechnungen)
  </div>
  <div class="ub-cards">
    <div class="ub-card">
      <div class="ub-card-label">Netto</div>
      <div class="ub-card-value"><%= liefNetto.toFixed(2).replace('.',',') %> €</div>
    </div>
    <div class="ub-card ub-card-primary">
      <div class="ub-card-label">Brutto (inkl. 7% USt)</div>
      <div class="ub-card-value"><%= liefBrutto.toFixed(2).replace('.',',') %> €</div>
      <div class="ub-card-sub">USt: <%= (liefBrutto - liefNetto).toFixed(2).replace('.',',') %> €</div>
    </div>
  </div>
</div>

<!-- ══ TAGESKASSE ════════════════════════════════════════════════════════════ -->
<div class="ub-section">
  <div class="ub-section-title">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 3H8a2 2 0 00-2 2v2h12V5a2 2 0 00-2-2z"/></svg>
    Tageskasse (Ladengeschäft)
  </div>
  <div class="ub-cards">
    <div class="ub-card">
      <div class="ub-card-label">Umsatz 7% MwSt</div>
      <div class="ub-card-value"><%= sumR7.toFixed(2).replace('.',',') %> € <span style="font-size:0.8rem;font-weight:400">brutto</span></div>
      <div class="ub-card-sub">netto: <%= (sumR7/1.07).toFixed(2).replace('.',',') %> € &nbsp;·&nbsp; USt: <%= ladenUst7.toFixed(2).replace('.',',') %> €</div>
    </div>
    <div class="ub-card">
      <div class="ub-card-label">Umsatz 19% MwSt</div>
      <div class="ub-card-value"><%= sumR19.toFixed(2).replace('.',',') %> € <span style="font-size:0.8rem;font-weight:400">brutto</span></div>
      <div class="ub-card-sub">netto: <%= (sumR19/1.19).toFixed(2).replace('.',',') %> € &nbsp;·&nbsp; USt: <%= ladenUst19.toFixed(2).replace('.',',') %> €</div>
    </div>
    <div class="ub-card ub-card-warn">
      <div class="ub-card-label">Lottokasse (weitergeleitet)</div>
      <div class="ub-card-value" style="color:#e67e22">− <%= sumLotto.toFixed(2).replace('.',',') %> €</div>
      <div class="ub-card-sub">Nicht im Umsatz enthalten</div>
    </div>
    <div class="ub-card ub-card-primary">
      <div class="ub-card-label">Laden-Umsatz gesamt</div>
      <div class="ub-card-value"><%= ladenBrutto.toFixed(2).replace('.',',') %> € <span style="font-size:0.8rem;font-weight:400">brutto</span></div>
      <div class="ub-card-sub">netto: <%= ladenNetto.toFixed(2).replace('.',',') %> € &nbsp;·&nbsp; USt: <%= (ladenBrutto - ladenNetto).toFixed(2).replace('.',',') %> €</div>
    </div>
  </div>
</div>

<!-- ══ GESAMT ════════════════════════════════════════════════════════════════ -->
<div class="ub-section ub-total-section">
  <div class="ub-section-title" style="color:#fff">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
    Gesamtumsatz
  </div>
  <div class="ub-cards">
    <div class="ub-card ub-card-dark">
      <div class="ub-card-label">Gesamt netto</div>
      <div class="ub-card-value"><%= gesamtNetto.toFixed(2).replace('.',',') %> €</div>
    </div>
    <div class="ub-card ub-card-gold">
      <div class="ub-card-label">Gesamt brutto</div>
      <div class="ub-card-value" style="font-size:1.6rem"><%= gesamtBrutto.toFixed(2).replace('.',',') %> €</div>
      <div class="ub-card-sub">USt gesamt: <%= (gesamtBrutto - gesamtNetto).toFixed(2).replace('.',',') %> €</div>
    </div>
  </div>
</div>

<style>
.ub-section {
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 20px 22px;
  margin-bottom: 18px;
}
.ub-total-section {
  background: var(--dark);
  border-color: var(--dark);
}
.ub-section-title {
  display: flex;
  align-items: center;
  gap: 8px;
  font-weight: 700;
  font-size: 0.88rem;
  letter-spacing: 0.03em;
  color: var(--dark);
  margin-bottom: 16px;
}
.ub-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 12px;
}
.ub-card {
  background: var(--bg, #f9f5ef);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 14px 18px;
}
.ub-card-primary { background: #fff; border-color: var(--gold); }
.ub-card-warn    { background: #fffaf4; border-color: #f0a04b; }
.ub-card-dark    { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.15); }
.ub-card-gold    { background: var(--gold); border-color: var(--gold); }

.ub-card-label { font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--mid); margin-bottom: 6px; }
.ub-card-dark  .ub-card-label,
.ub-card-gold  .ub-card-label { color: rgba(255,255,255,0.75); }

.ub-card-value { font-size: 1.3rem; font-weight: 700; color: var(--dark); }
.ub-card-dark  .ub-card-value,
.ub-card-gold  .ub-card-value { color: #fff; }

.ub-card-sub { font-size: 0.78rem; color: var(--mid); margin-top: 4px; }
.ub-card-dark .ub-card-sub,
.ub-card-gold .ub-card-sub { color: rgba(255,255,255,0.65); }
</style>
