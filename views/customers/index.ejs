<div class="page-header">
  <h2>Kunden</h2>
  <a href="/kunden/neu" class="btn-primary">+ Neuer Kunde</a>
</div>

<div class="card">
  <% if (customers.length === 0) { %>
    <p class="empty-state">Noch keine Kunden angelegt. <a href="/kunden/neu">Ersten Kunden anlegen</a></p>
  <% } else { %>
  <table class="data-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Rechnungsadresse</th>
        <th>Lieferadresse</th>
        <th>Kostenstelle</th>
        <th>Aktionen</th>
      </tr>
    </thead>
    <tbody>
      <% customers.forEach(c => { %>
      <tr>
        <td><strong><%= c.name %></strong></td>
        <td class="text-muted"><%= [c.billing_street, c.billing_zip + ' ' + c.billing_city].filter(x=>x.trim()).join(', ') || '—' %></td>
        <td class="text-muted">
          <%= [c.delivery_contact, c.delivery_street, c.delivery_zip + ' ' + c.delivery_city].filter(x=>x&&x.trim()).join(', ') || '—' %>
        </td>
        <td class="text-muted"><%= c.cost_center || '—' %></td>
        <td>
          <div class="action-links">
            <a href="/kunden/<%= c.id %>/bearbeiten">Bearbeiten</a>
            <form action="/kunden/<%= c.id %>/loeschen" method="POST" style="display:inline" onsubmit="return confirm('Kunden wirklich löschen?')">
              <button type="submit" class="link-danger">Löschen</button>
            </form>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
