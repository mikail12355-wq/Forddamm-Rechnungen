<div class="page-header">
  <h2><%= article ? 'Artikel bearbeiten' : 'Neuer Artikel' %></h2>
  <a href="/artikel" class="btn-secondary">← Zurück</a>
</div>

<div class="card" style="max-width:480px">
  <form action="<%= article ? '/artikel/' + article.id + '/bearbeiten' : '/artikel/neu' %>" method="POST">
    <div class="form-group">
      <label>Artikelname <span class="required">*</span></label>
      <input type="text" name="name" value="<%= article ? article.name : '' %>" required autofocus />
    </div>
    <div class="form-group">
      <label>Einzelpreis netto (€) <span class="required">*</span></label>
      <input type="text" name="unit_price" value="<%= article ? article.unit_price.toFixed(2).replace('.',',') : '' %>" required placeholder="4,50" />
    </div>
    <% if (article) { %>
    <div class="form-group">
      <label>
        <input type="checkbox" name="active" value="1" <%= article.active ? 'checked' : '' %> />
        Aktiv (erscheint in Rechnungsformular)
      </label>
    </div>
    <% } %>
    <div style="display:flex;gap:12px">
      <button type="submit" class="btn-primary"><%= article ? 'Speichern' : 'Artikel anlegen' %></button>
      <a href="/artikel" class="btn-secondary">Abbrechen</a>
    </div>
  </form>
</div>
